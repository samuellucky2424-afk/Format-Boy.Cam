VITE_API_BASE_URL=https://your-backend.example.com
VITE_PAYSTACK_PUBLIC_KEY=your_paystack_public_key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

PAYSTACK_SECRET_KEY=your_paystack_secret_key

# GitHub Releases updater settings (preferred)
DESKTOP_GITHUB_OWNER=samuellucky2424-afk
DESKTOP_GITHUB_REPO=Format-Boy.Cam
DESKTOP_GITHUB_EXE_PATTERN=^Format-Boy CAM Desktop Setup .*\.exe$

DESKTOP_LATEST_VERSION=2.0.1
DESKTOP_ARTIFACT_TYPE=installer
DESKTOP_RELEASE_NOTES=Format-Boy CAM Desktop 2.0.1
DESKTOP_DOWNLOAD_SHA256=

# Supabase Storage updater settings
# Example object path: desktop/Format-Boy CAM Desktop Setup {version}.exe
DESKTOP_SUPABASE_BUCKET=format-boy-updates
DESKTOP_SUPABASE_PATH=desktop/Format-Boy CAM Desktop Setup {version}.exe
DESKTOP_SUPABASE_ACCESS=signed
DESKTOP_SIGNED_URL_EXPIRES=7200

# Optional direct URL fallback if Storage is not configured
DESKTOP_DOWNLOAD_URL=
